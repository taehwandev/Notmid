NOTMID_API_BASE_URL=http://localhost:8787
NEXT_PUBLIC_NOTMID_AUTH_PROVIDER=fake
NEXT_PUBLIC_NOTMID_WEB_BASE_PATH=/notmid

# Public Firebase web config is safe to expose, but keep real project values
# in ignored environment files or deployment secret/config stores.
NEXT_PUBLIC_NOTMID_FIREBASE_API_KEY=
NEXT_PUBLIC_NOTMID_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_NOTMID_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_NOTMID_FIREBASE_APP_ID=
NEXT_PUBLIC_NOTMID_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_NOTMID_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_NOTMID_GOOGLE_CLIENT_ID=

# Do not commit service account JSON, private keys, or App Check debug tokens.
# NODE_ENV=production requires NOTMID_API_BASE_URL=https://... and an explicit
# NEXT_PUBLIC_NOTMID_AUTH_PROVIDER value of firebase or disabled. Firebase mode
# also requires a public Google OAuth client ID for permanent account sign-in.
