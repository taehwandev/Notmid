NOTMID_API_PORT=8787
NOTMID_WEB_ORIGIN=http://localhost:3000
NOTMID_AUTH_MODE=fake
NOTMID_DATA_BACKEND=fixture
NOTMID_MUTATION_RATE_LIMIT_MAX=120
NOTMID_MUTATION_RATE_LIMIT_WINDOW_MS=60000

# Production deployments should use real secret storage.
# Do not commit Firebase Admin SDK JSON, service account JSON, or private keys.
# NODE_ENV=production requires NOTMID_WEB_ORIGIN=https://... and
# NOTMID_AUTH_MODE=disabled or firebase. Fake auth is local-only.
# Firebase auth mode uses this public project id to verify SecureToken ID tokens.
FIREBASE_PROJECT_ID=
# NODE_ENV=production requires NOTMID_DATA_BACKEND=postgres and DATABASE_URL.
DATABASE_URL=
